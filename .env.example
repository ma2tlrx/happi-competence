# ── Sentry — Error Tracking ─────────────────────────────────────────
# https://sentry.io → New Project → React → DSN
VITE_SENTRY_DSN=

# ── PostHog — Analytics ──────────────────────────────────────────────
# https://posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Supabase — Backend / Base de données ─────────────────────────────
# https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Clerk — Authentification ─────────────────────────────────────────
# https://clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=

# ── Resend — Emails ──────────────────────────────────────────────────
# Côté serveur uniquement (Vercel API Routes) — ne pas exposer côté client
RESEND_API_KEY=

# ── Upstash Redis — Cache ────────────────────────────────────────────
# https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
